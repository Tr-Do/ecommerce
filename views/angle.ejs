<% layout('layouts/boilerplate') %>

<div
  class="canvas-wrap border border-secondary-subtle d-block mt-5 w-75 h-50 mb-5 mx-auto"
>
  <canvas id="canvas d-block w-100 h-auto"></canvas>
</div>
<div
  class="controls d-flex flex-column justify-content-center align-items-center flex-wrap gap-3 mb-3"
>
  <span id="angleOutput"></span>
  <input type="file" id="imageInput" accept="image/*" class="ms-5 ps-5" />
  <span id="resetBtn"><button class="btn btn-danger">Reset</button></span>
  <span id="status"
    ><button class="btn btn-primary">Upload an image</button></span
  >
</div>
